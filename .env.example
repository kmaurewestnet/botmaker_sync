BOTMAKER_ACCESS_TOKEN=your-access-token-here

# Host can be localhost, a raw IP, or a domain name -- the driver treats them
# identically. For anything that ISN'T localhost, append ?sslmode=require (or
# verify-full if you have a CA cert to validate against): the connection
# otherwise defaults to "sslmode=prefer", which silently falls back to an
# UNENCRYPTED connection if the server doesn't offer TLS.
DATABASE_URL=postgresql://user:password@localhost:5432/botmaker
# DATABASE_URL=postgresql://user:password@db.example.com:5432/botmaker?sslmode=require
# DATABASE_URL=postgresql://user:password@203.0.113.10:5432/botmaker?sslmode=require

# Optional, defaults to https://api.botmaker.com/v2.0
# BOTMAKER_API_BASE_URL=https://api.botmaker.com/v2.0
